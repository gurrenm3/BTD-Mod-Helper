<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <SourceGeneratorsVersion>1.1.1</SourceGeneratorsVersion>
    </PropertyGroup>

    <PropertyGroup>
        <!--BloonsTD6 property gets automatically set correctly when this file is generated by the Mod Helper on startup-->
        <BloonsTD6 Condition="'$(BloonsTD6)' == ''">C:\Program Files (x86)\Steam\steamapps\common\BloonsTD6</BloonsTD6>
        <Il2CppAssemblies>$(BloonsTD6)\MelonLoader\Il2CppAssemblies</Il2CppAssemblies>
        <ManagedFolder>$(BloonsTD6)\MelonLoader\net6</ManagedFolder>
        <OutputFolder Condition="'$(OutputFolder)' == ''">Mods</OutputFolder>
        <PlatformTarget>x64</PlatformTarget>
        <RunCommand>$(BloonsTD6)\BloonsTD6.exe</RunCommand>
        <RunWorkingDirectory>$(BloonsTD6)</RunWorkingDirectory>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    </PropertyGroup>

    <!--References to MelonLoader dependencies-->
    <ItemGroup>
        <Reference Include="$(BloonsTD6)\MelonLoader\net6\MelonLoader.dll" Private="false"/>
        <Reference Include="$(BloonsTD6)\MelonLoader\net6\0Harmony.dll" Private="false"/>
    </ItemGroup>

    <!--References to BTD6 dependencies-->
    <ItemGroup Condition="'$(JustMelonloader)' != 'true'">
        <Reference Include="$(Il2CppAssemblies)\Assembly-CSharp.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2Cppmscorlib.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppSystem.Core.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppSystem.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppNinjaKiwi.Common.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppNinjaKiwi.GUTS.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppNinjaKiwi.LiNK.Client.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Unity.InputSystem.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Unity.ResourceManager.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Unity.TextMeshPro.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.AnimationModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.AssetBundleModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.AudioModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.CoreModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.InputLegacyModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.ImageConversionModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.JSONSerializeModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.TextRenderingModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.UI.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.UIElementsModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.UIModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppNewtonsoft.Json.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Unity.Addressables.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.IMGUIModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppFacepunch.Steamworks.Win64.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppUniWebView-CSharp.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.ParticleSystemModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.PhysicsModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.VideoModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\UnityEngine.ScreenCaptureModule.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Unity.RenderPipelines.Universal.Runtime.dll" Private="false"/>
        <Reference Include="$(Il2CppAssemblies)\Il2CppNinjaKiwi.Localization.dll" Private="false"/>

        <Reference Include="$(ManagedFolder)\UnityEngine.Il2CppAssetBundleManager.dll" Private="false"/>
        <Reference Include="$(ManagedFolder)\UnityEngine.Il2CppImageConversionManager.dll" Private="false"/>
        <Reference Include="$(ManagedFolder)\Newtonsoft.Json.dll" Private="false"/>
        <Reference Include="$(ManagedFolder)\Il2CppInterop.Runtime.dll" Private="false"/>
    </ItemGroup>

    <!--Referencing mod dependencies, supporting subfolders-->
    <Target Name="ResolveModReferences" BeforeTargets="ResolveAssemblyReferences;ResolveAssemblyReferencesDesignTime">
        <!--Mod Helper dependency-->
        <ItemGroup Condition="$(DontReferenceModHelper) != 'true'">
            <_ModHelperDll Include="$(BloonsTD6)\Mods\**\Btd6ModHelper.dll"/>
            <Reference Condition="'@(_ModHelperDll)' != ''"
                       Include="BloonsTD6 Mod Helper"
                       HintPath="%(_ModHelperDll.FullPath)"
                       SpecificVersion="false"
                       Private="false"/>
        </ItemGroup>

        <!--Other mod dependencies, listed in <Dependencies> as a list of dll names without extension-->
        <ItemGroup Condition="'$(Dependencies)' != ''">
            <_Dependency Include="$(Dependencies)"/>
            <_ActiveDependencyDll Include="$(BloonsTD6)\Mods\**\%(_Dependency.Identity).dll"/>
            <_DisabledDependencyDll Include="$(BloonsTD6)\Disabled Mods\**\%(_Dependency.Identity).dll"
                                    Exclude="@(_ActiveDependencyDll->'$(BloonsTD6)\Disabled Mods\**\%(Filename).dll')"/>

            <_DependencyDll Include="@(_ActiveDependencyDll)"/>
            <_DependencyDll Include="@(_DisabledDependencyDll)"/>

            <Reference Include="@(_DependencyDll->'%(Filename)')"
                       HintPath="%(_DependencyDll.FullPath)"
                       SpecificVersion="False"
                       Private="false"/>
        </ItemGroup>
    </Target>

    <!--Automatic embeds-->
    <ItemGroup Condition="'$(AutoEmbed)' != 'false'">
        <EmbeddedResource Include="**/*.png"/>
        <EmbeddedResource Include="**/*.jpg"/>
        <EmbeddedResource Include="**/*.png.json"/>
        <EmbeddedResource Include="**/*.jpg.json"/>
        <EmbeddedResource Include="**/*.wav"/>
        <EmbeddedResource Include="**/*.mp3"/>
        <EmbeddedResource Include="**/*.ogg"/>
        <EmbeddedResource Include="**/*.flac"/>
        <EmbeddedResource Include="**/*.aac"/>
        <EmbeddedResource Include="**/*.wma"/>
        <EmbeddedResource Include="**/*.m4a"/>
        <EmbeddedResource Include="**/*.bundle"/>
        <EmbeddedResource Include="**/*.bytes"/>
        <EmbeddedResource Condition="Exists('ModHelperData.json')" Include="ModHelperData.json"/>
        <EmbeddedResource Condition="Exists('ModHelperData.txt')" Include="ModHelperData.txt"/>
        <EmbeddedResource Remove="**/Screenshot*.png"/>
        <EmbeddedResource Include="Localization/**/*.json"/>
        <None Remove="**/LICENSE"/>
    </ItemGroup>

    <ItemGroup Condition="'$(ModHelperSourceGenerators)' != 'false'">
        <CompilerVisibleProperty Include="RootNamespace"/>
        <CompilerVisibleProperty Include="ProjectDir"/>
        <CompilerVisibleProperty Include="AssemblyName"/>
        <CompilerVisibleProperty Include="MSBuildProjectName"/>
        <CompilerVisibleProperty Include="GenerateModResources"/>
        <CompilerVisibleProperty Include="GenerateActionsWorkflow"/>
    </ItemGroup>
    <PropertyGroup Condition="'$(ModHelperSourceGenerators)' != 'false' And '$(GenerateModResources)' != 'false'">
        <AdditionalFileItemNames Condition="'$(GenerateModResources)' != 'false'">$(AdditionalFileItemNames);EmbeddedResource</AdditionalFileItemNames>
    </PropertyGroup>
    <ItemGroup Condition="'$(ModHelperSourceGenerators)' != 'false' And '$(GenerateActionsWorkflow)' != 'false' And Exists('$(MSBuildProjectDirectory)\.github\workflows\build.yml')">
        <AdditionalFiles Include="ModHelperData.*"/>
        <AdditionalFiles Include="**/CHANGELOG.md"/>
        <AdditionalFiles Include="**/LATEST.md"/>
        <AdditionalFiles Include="**/thunderstore.toml"/>
        <AdditionalFiles Include="$(MSBuildProjectDirectory)\.github\workflows\build.yml"/>
    </ItemGroup>
    <ItemGroup Condition="'$(ModHelperSourceGenerators)' != 'false' And '$(DontReferenceModHelper)' != 'true'">
        <PackageReference Condition="!Exists('..\BTD-Mod-Helper\SourceGenerators\SourceGenerators.csproj')"
                          Include="Btd6ModHelper.SourceGenerators" Version="$(SourceGeneratorsVersion)" PrivateAssets="all"/>
        <ProjectReference Condition="Exists('..\BTD-Mod-Helper\SourceGenerators\SourceGenerators.csproj')"
                          Include="..\BTD-Mod-Helper\SourceGenerators\SourceGenerators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
        <Analyzer Condition="Exists('..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\SourceGenerators.dll')"
                  Include="..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\*.dll"
                  Exclude="..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\SourceGenerators.dll;..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\Microsoft.CodeAnalysis*.dll;..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\Microsoft.CSharp.dll;..\BTD-Mod-Helper\SourceGenerators\bin\$(Configuration)\System.*.dll"/>
    </ItemGroup>

    <!--Post build events to copy dll/xml to mods folder. Works even if game is currently running-->
    <Target Name="MoveDllToMods" AfterTargets="Build" Condition="Exists('$(TargetDir)$(TargetName).dll')">
        <Message Text="Copying $(ProjectName).dll to $(OutputFolder) Folder..." Importance="High"/>

        <Delete Condition="Exists('$(BloonsTD6)\BTD6ModHelper\Old Mods\$(ProjectName).dll')"
                Files="$(BloonsTD6)\BTD6ModHelper\Old Mods\$(ProjectName).dll"/>

        <Move Condition="Exists('$(BloonsTD6)\$(OutputFolder)\$(ProjectName).dll')"
              SourceFiles="$(BloonsTD6)\$(OutputFolder)\$(ProjectName).dll"
              DestinationFiles="$(BloonsTD6)\BTD6ModHelper\Old Mods\$(ProjectName).dll"/>

        <Copy SourceFiles="$(TargetDir)$(TargetName).dll"
              DestinationFiles="$(BloonsTD6)\$(OutputFolder)\$(ProjectName).dll"/>
    </Target>
    <Target Name="MoveXmlToMods" AfterTargets="Build" Condition="Exists('$(TargetDir)$(ProjectName).xml')">
        <Message Text="Copying $(ProjectName).xml to $(OutputFolder) Folder..." Importance="High"/>

        <Copy SourceFiles="$(TargetDir)$(ProjectName).xml"
              DestinationFiles="$(BloonsTD6)\$(OutputFolder)\$(ProjectName).xml"/>
    </Target>

    <!--Keep launchSettings.json up to date with the one from Mod Sources, unless the mod author sets DontCopyLaunchSettings-->
    <Target Name="SyncLaunchSettings" BeforeTargets="PrepareForBuild"
            Condition="Exists('$(MSBuildThisFileDirectory)launchSettings.json') AND '$(DontCopyLaunchSettings)' == ''">
        <MakeDir Directories="$(ProjectDir)Properties"/>
        <Copy SourceFiles="$(MSBuildThisFileDirectory)launchSettings.json"
              DestinationFiles="$(ProjectDir)Properties\launchSettings.json"
              SkipUnchangedFiles="true"/>
    </Target>

    <!-- ILRepack support -->

    <ItemGroup Condition="$(IncludeLibs) != ''">
        <PackageReference Include="ILRepack.Lib.MSBuild.Task" Version="2.0.29" GeneratePathProperty="true">
            <ExcludeAssets>build</ExcludeAssets> <!-- Ignore ILRepack.Lib.MSBuild.Task.targets, define task manually below -->
        </PackageReference>
    </ItemGroup>

    <UsingTask Condition="$(IncludeLibs) != ''" TaskName="ILRepack" AssemblyFile="$(PkgILRepack_Lib_MSBuild_Task)\build\ILRepack.Lib.MSBuild.Task.dll"/>

    <Target Name="Definitons" Condition="$(IncludeLibs) != ''">
        <ItemGroup>
            <AssemblyFile Include="$(TargetDir)$(TargetName).dll"/>
            <InputAssemblies Include="@(AssemblyFile)"/>

            <IncludedAssemblies Include="@(ReferencePathWithRefAssemblies)"
                                Condition="$([System.String]::new(';$([System.Text.RegularExpressions.Regex]::Replace($(IncludeLibs), '\s*[%2C;]\s*', ';'));').Contains(';%(filename);'))"/>
            <InputAssemblies Include="@(IncludedAssemblies)"/>
        </ItemGroup>
    </Target>

    <!--When in Debug mode, copy the libraries into UserLibs-->
    <Target Name="DebugCopyLibs" AfterTargets="Build" DependsOnTargets="Definitons"
            Condition="'$(Configuration)' == 'Debug' AND '$(IncludeLibs)' != ''">
        <Message Text="Copying Included Libraries to UserLibs folder..." Importance="high"/>
        <Copy SourceFiles="@(IncludedAssemblies)" DestinationFolder="$(BloonsTD6)\UserLibs"/>
    </Target>

    <!--When in Release mode, pack the libraries into the dll-->
    <Target Name="ReleaseILRepack" AfterTargets="Build" BeforeTargets="MoveDllToMods" DependsOnTargets="Definitons"
            Condition="'$(Configuration)' != 'Debug' AND '$(IncludeLibs)' != ''">
        <Copy Condition="Exists('$(BloonsTD6)\Mods\Btd6ModHelper.dll') AND '$(DontReferenceModHelper)' != 'true'"
              SourceFiles="$(BloonsTD6)\Mods\Btd6ModHelper.dll"
              DestinationFiles="$(TargetDir)BloonsTD6 Mod Helper.dll"
              SkipUnchangedFiles="true"/>
        <ItemGroup>
            <LibraryPaths Include="$(BloonsTD6)\MelonLoader"/>
            <LibraryPaths Include="$(BloonsTD6)\MelonLoader\Managed"/>
            <LibraryPaths Include="$(BloonsTD6)\MelonLoader\net6"/>
            <LibraryPaths Include="$(BloonsTD6)\MelonLoader\Il2CppAssemblies"/>
            <LibraryPaths Include="$(NetCoreRoot)packs\Microsoft.NETCore.App.Ref\6.0.0\ref\net6.0"/>
            <LibraryPaths Include="$(BloonsTD6)\Mods"/>
            <LibraryPaths Include="$(TargetDir)"/>
        </ItemGroup>

        <ILRepack
                Parallel="true"
                InputAssemblies="@(InputAssemblies)"
                TargetKind="Dll"
                OutputFile="@(AssemblyFile)"
                Internalize="false"
                LibraryPath="@(LibraryPaths)"/>
    </Target>
</Project>
